# ═══════════════════════════════════════════════════════════════
# AeroXe Backend — Environment Configuration
# Copy to .env and fill in values for your environment.
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://aeraxe:secret@localhost:5432/aeraxe
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_CONNECT_TIMEOUT_SECS=10
DB_IDLE_TIMEOUT_SECS=300

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── NATS ──────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT / Auth ────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=30

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated origins. Leave empty for allow-all (dev mode).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── SMTP (Email) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@aeraxe.com
SMTP_PASS=your-smtp-password

# ── MinIO / Object Storage ────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aeraxe-documents

# ── Logging ───────────────────────────────────────────────────
RUST_LOG=info,aeraxe_backend=debug,sqlx=warn
