# =============================================================================
# AeroXe Broadband Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ── Server ──────────────────────────────────────────────────────────────────
SERVER_ADDR=0.0.0.0:8000
APP_ENV=development

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aeroxe:secret@localhost:5432/aeroxe
DB_MAX_CONNECTIONS=20

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── NATS JetStream ──────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT Authentication ──────────────────────────────────────────────────────
# Generate RSA key pair: openssl genrsa 2048 | openssl rsa -pubout
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_KEY_ROTATION_DAYS=30

# ── CORS Origins (comma-separated) ──────────────────────────────────────────
CORS_ORIGINS=https://aeroxebroadband.com,https://admin.aeroxe.com

# ── MinIO / S3 Object Storage ──────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aeroxe-documents
MINIO_REGION=us-east-1

# ── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=AeroXe Broadband
SMTP_FROM_EMAIL=noreply@aeroxebroadband.com

# ── SMS Provider (MSG91) ───────────────────────────────────────────────────
SMS_API_KEY=
SMS_SENDER_ID=AEROXE

# ── Payment Gateway (Razorpay) ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=aeroxe_backend=debug,tower_http=debug

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5
RATE_LIMIT_API_READ=100
RATE_LIMIT_API_WRITE=30
RATE_LIMIT_UPLOAD=10
